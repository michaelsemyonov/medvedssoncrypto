{
  "name": "medvedsson-crypto",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.2",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @medvedsson/api --filter @medvedsson/pwa dev",
    "dev:api": "pnpm --filter @medvedsson/api dev",
    "dev:pwa": "pnpm --filter @medvedsson/pwa dev",
    "start:api": "pnpm --filter @medvedsson/api start",
    "build:pwa": "pnpm --filter @medvedsson/pwa build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
