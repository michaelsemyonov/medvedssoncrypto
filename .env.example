NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://root:root@localhost:3306/crypto_dryrun
EXCHANGE=bybit
EXCHANGE_TIMEOUT_MS=10000
EXCHANGE_RATE_LIMIT_MS=300
TIMEFRAME=5m
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
DRY_RUN=true
ALLOW_SHORT=true
STRATEGY_KEY=momentum_96_5_72
STRATEGY_VERSION=1.0.0
SIGNAL_N=96
SIGNAL_K=5
SIGNAL_H_BARS=72
FILL_MODEL=next_open
FEE_RATE=0.001
SLIPPAGE_BPS=5
POSITION_SIZING_MODE=fixed_usdt
FIXED_USDT_PER_TRADE=100
EQUITY_START_USDT=10000
MAX_OPEN_POSITIONS=5
COOLDOWN_BARS=3
MAX_DAILY_DRAWDOWN_PCT=5
MAX_CONSECUTIVE_LOSSES=5
POLL_INTERVAL_MS=15000
ENABLE_CANDLE_STORAGE=true
RUNNER_AUTOSTART=true
LOG_LEVEL=info
ADMIN_PASSWORD=change_me
SESSION_SECRET=replace_with_at_least_32_characters
SESSION_TTL_HOURS=168
API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
WEB_PUSH_VAPID_PUBLIC_KEY=replace_me
WEB_PUSH_VAPID_PRIVATE_KEY=replace_me
WEB_PUSH_CONTACT=mailto:you@example.com
