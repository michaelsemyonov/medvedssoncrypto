NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://root:root@localhost:3306/crypto_dryrun
# Symbol, strategy, execution, and risk settings are stored in MySQL.
# On first boot the API seeds default symbol rows that you can edit from the PWA.
ENABLE_CANDLE_STORAGE=true
RUNNER_AUTOSTART=true
LOG_LEVEL=info
ADMIN_PASSWORD=change_me
SESSION_SECRET=replace_with_at_least_32_characters
SESSION_TTL_HOURS=168
API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
WEB_PUSH_VAPID_PUBLIC_KEY=replace_me
WEB_PUSH_VAPID_PRIVATE_KEY=replace_me
WEB_PUSH_CONTACT=mailto:you@example.com
